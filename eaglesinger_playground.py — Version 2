BANNER = r"""
╔══════════════════════════════════════════════╗
║        EagleSinger – Chaos Playground V2     ║
╚══════════════════════════════════════════════╝
"""

def render_menu():
    print(BANNER)
    print("\n✨ ฟีเจอร์ที่มีในไฟล์นี้ (1–8):\n")
    for idx, data in FEATURES.items():
        print(f"  [{idx}] {data['title']}")
    print("\nพิมพ์หมายเลขเพื่อดูรายละเอียด หรือกด Enter เพื่อออก")

def show_feature(idx):
    data = FEATURES.get(idx)
    if not data:
        return
    print("\n" + "=" * 60)
    print(data["title"])
    print("=" * 60 + "\n")
    print(textwrap.fill(data["body"].strip(), width=80))
    print("\n" + "=" * 60 + "\n")

def main():
    while True:
        render_menu()
        choice = input("> ").strip()
        if not choice:
            break
        if choice.isdigit():
            show_feature(int(choice))

if __name__ == "__main__":
    main()
